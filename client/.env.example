# Copy this file to ".env" (same folder) and fill in your real key.
# .env is gitignored. Note: Vite only exposes vars that start with VITE_.
# This key WILL be visible in the browser (that's normal for Maps JS) —
# protect it with HTTP-referrer restrictions in Google Cloud Console, not by hiding it.

VITE_MAPS_KEY=paste_your_google_maps_js_api_key_here

# Required for AdvancedMarkerElement (replaces the deprecated google.maps.Marker).
# Create a Map ID in Google Cloud Console → Google Maps Platform → Map Management.
# Attach a dark Cloud Map Style there to restore the custom dark theme.
# Falls back to "DEMO_MAP_ID" (Google's test ID) which works in local dev but
# produces a default light-theme map.
VITE_MAPS_MAP_ID=paste_your_map_id_here
