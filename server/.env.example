# ── Gemini ───────────────────────────────────────────────────────────────────
# Required. Get yours at https://aistudio.google.com/
GEMINI_API_KEY=paste_your_gemini_api_key_here

# ── Google Cloud ──────────────────────────────────────────────────────────────
# Required. Your GCP project ID (visible in the Cloud Console header).
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# ── Cloud Storage ─────────────────────────────────────────────────────────────
# Required. Create with:
#   gsutil mb -l asia-south1 gs://your-bucket-name
#   gcloud storage buckets add-iam-policy-binding gs://your-bucket-name \
#     --member=serviceAccount:YOUR_SA@PROJECT.iam.gserviceaccount.com \
#     --role=roles/storage.objectAdmin
GCS_BUCKET_NAME=your-gcs-bucket-name

# ── Signed URL Auth (Cloud Run only) ─────────────────────────────────────────
# Required on Cloud Run with workload identity (no key file).
# Omit when using GOOGLE_APPLICATION_CREDENTIALS (local dev with a key file).
# The SA must have roles/iam.serviceAccountTokenCreator on itself:
#   gcloud iam service-accounts add-iam-policy-binding SA_EMAIL \
#     --member=serviceAccount:SA_EMAIL --role=roles/iam.serviceAccountTokenCreator
SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# ── Local dev auth (alternative to SERVICE_ACCOUNT_EMAIL) ────────────────────
# Uncomment and point to a downloaded service account JSON key for local dev.
# Never commit this file. See: https://cloud.google.com/iam/docs/keys-create-delete
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
